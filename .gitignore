graphify-out/

# Local NuGet pack outputs (see scripts/install-gauntletci-global-tool.ps1 → nupkg-local/)
nupkg-local/
nupkg-extract/
nupkg/
packaging/*.nupkg

# Cursor agent config (optional commit — un-ignore rules under .cursor/)
!.cursor/
!.cursor/**/*
!.cursor/**/*.mdc

# GauntletCI model cache (Phi-4 Mini ONNX — ~2.8 GB, never commit)
.gauntletci/
**/*.onnx
**/*.onnx.data
**/phi4-mini-instruct-*

