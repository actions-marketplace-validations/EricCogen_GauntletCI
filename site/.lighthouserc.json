{
  "ci": {
    "collect": {
      "staticDistDir": "./out",
      "url": [
        "/",
        "/about/",
        "/articles/",
        "/docs/",
        "/pricing/",
        "/benchmark/",
        "/articles/why-tests-miss-bugs/",
        "/articles/why-code-review-misses-bugs/",
        "/articles/what-is-diff-based-analysis/",
        "/articles/detect-breaking-changes-before-merge/",
        "/articles/can-ai-code-review-be-deterministic/",
        "/articles/behavioral-change-risk-formal-framework/",
        "/articles/case-studies/",
        "/articles/the-asymmetry-of-change/"
      ],
      "numberOfRuns": 1
    },
    "assert": {
      "preset": "lighthouse:no-pwa",
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.8 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.85 }],
        "categories:seo": ["error", { "minScore": 0.9 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
